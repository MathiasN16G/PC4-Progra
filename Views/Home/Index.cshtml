@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">
    <div class="card shadow p-4 border-0" style="background-color: #d9f1ff; border-radius: 15px;">
        <h1 class="text-center mb-3" style="color: #007acc;">Evaluador Inteligente</h1>
        <p class="lead text-center text-dark">Hola, ten un lindo dia </p>
        <p class="text-center">Escribe tu opinión sobre un producto para detectar su sentimiento:</p>

        <form method="post" asp-action="Analizar" class="mt-4">
    <div class="form-group">
        <label for="userId" class="form-label">Tu código de usuario (Ej: U1):</label>
        <input type="text" name="userId" class="form-control mb-3" required />
    </div>
    <div class="form-group">
        <label for="opinion" class="form-label">Tu opinión:</label>
        <textarea name="opinion" class="form-control" rows="4" placeholder="Ejemplo: Me encantó la calidad del producto." required></textarea>
    </div>
    <div class="text-center mt-3">
        <button type="submit" class="btn btn-primary px-4" style="background-color: #0099e6; border: none; font-weight: bold;">
            Analizar Sentimiento
        </button>
    </div>
</form>

    </div>
</div>
