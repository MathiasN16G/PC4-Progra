@{
    ViewData["Title"] = "Análisis de Opiniones";
}

<h2>@ViewData["Title"]</h2>

<form method="post" asp-action="Analizar">
    <label for="opinion">Escribe tu opinión sobre un producto:</label><br />
    <textarea name="opinion" rows="4" cols="60" required></textarea><br /><br />
    <button type="submit">Analizar Sentimiento</button>
</form>
